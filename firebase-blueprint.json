{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and role.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "customId": { "type": "string", "description": "Custom UID in format IND-USERNAME-5NUMBER" },
        "role": { "type": "string", "enum": ["artist", "admin"] },
        "walletBalance": { "type": "number", "description": "Current balance in Rupees" },
        "totalEarned": { "type": "number", "description": "Lifetime earnings" },
        "totalWithdrawn": { "type": "number", "description": "Lifetime withdrawals" },
        "planId": { "type": "string", "description": "Current subscription plan ID" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Plan": {
      "title": "Pricing Plan",
      "description": "Subscription plan details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "currency": { "type": "string" },
        "interval": { "type": "string", "enum": ["month", "year"] },
        "features": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Subscription": {
      "title": "User Subscription",
      "description": "Details of an active user subscription.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "planId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "canceled", "past_due", "incomplete"] },
        "currentPeriodEnd": { "type": "string", "format": "date-time" }
      }
    },
    "Release": {
      "title": "Music Release",
      "description": "Information about a distributed music release.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "artist": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "in_review", "approved", "live", "rejected"] },
        "coverUrl": { "type": "string" },
        "audioUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "WithdrawalRequest": {
      "title": "Withdrawal Request",
      "description": "User request to withdraw funds from wallet.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string", "enum": ["UPI", "BANK"] },
        "details": {
          "type": "object",
          "properties": {
            "upiId": { "type": "string" },
            "bankName": { "type": "string" },
            "accountHolder": { "type": "string" },
            "accountNumber": { "type": "string" },
            "ifscCode": { "type": "string" }
          }
        },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "paid"] },
        "admin_notes": { "type": "string" },
        "processedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "method", "status"]
    },
    "Transaction": {
      "title": "Financial Transaction",
      "description": "Detailed earnings, adds, and payout records.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["earning", "withdrawal"] },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "description": { "type": "string" },
        "platform": { "type": "string", "description": "e.g. Spotify, Apple Music" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "SystemNotification": {
      "title": "System Notification",
      "description": "Global alerts and updates for artists.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "warning", "urgent"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "UserRequest": {
      "title": "User Request",
      "description": "Customer requests for metadata changes, profile linking, etc.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "ticketId": { "type": "string" },
        "type": { "type": "string" },
        "subject": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "in_review", "approved", "rejected", "completed"] },
        "priority": { "type": "string", "enum": ["normal", "high", "urgent"] },
        "releaseId": { "type": "string" },
        "releaseTitle": { "type": "string" },
        "data": { "type": "object" },
        "adminResponse": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Mail": {
      "title": "Email Trigger",
      "description": "Trigger automated emails via Firebase Extension.",
      "type": "object",
      "properties": {
        "to": { "type": "array", "items": { "type": "string" } },
        "message": {
          "type": "object",
          "properties": {
            "subject": { "type": "string" },
            "html": { "type": "string" },
            "text": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "ContentIdRequest": {
      "title": "Content ID Request",
      "description": "Requests for YouTube/Social Media Content ID activation.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "releaseId": { "type": "string" },
        "songName": { "type": "string" },
        "artistName": { "type": "string" },
        "songLink": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "adminResponse": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userEmail", "releaseId", "songName", "artistName", "songLink", "status"]
    },
    "RoyaltyReport": {
      "title": "Royalty Report Batch",
      "description": "Metadata for a bundle of royalty distributions.",
      "type": "object",
      "properties": {
        "reportName": { "type": "string" },
        "source": { "type": "string" },
        "period": { "type": "string" },
        "fileUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["uploaded", "processing", "processed", "approved"] },
        "totalRevenue": { "type": "number" },
        "totalStreams": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "RoyaltyEntry": {
      "title": "Individual Royalty Entry",
      "description": "Financial line item for a single track on a single platform.",
      "type": "object",
      "properties": {
        "reportId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "isrc": { "type": "string" },
        "platform": { "type": "string" },
        "streams": { "type": "number" },
        "revenue": { "type": "number" },
        "country": { "type": "string" },
        "matched": { "type": "boolean" },
        "reason": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/royalty_reports/{reportId}": {
      "schema": "RoyaltyReport",
      "description": "Batches of processed earnings"
    },
    "/royalty_entries/{entryId}": {
      "schema": "RoyaltyEntry",
      "description": "Line items for royalty distributions"
    },
    "/mail/{mailId}": {
      "schema": "Mail",
      "description": "Triggered emails collection"
    },
    "/content_id_requests/{requestId}": {
      "schema": "ContentIdRequest",
      "description": "Requests for Content ID protection"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Global user profiles"
    },
    "/user_requests/{requestId}": {
      "schema": "UserRequest",
      "description": "Customer support and metadata requests"
    },
    "/support_tickets/{ticketId}": {
      "schema": "UserRequest",
      "description": "Support tickets (using UserRequest schema)"
    },
    "/support_tickets/{ticketId}/messages/{messageId}": {
      "schema": {
        "type": "object",
        "properties": {
          "userId": { "type": "string" },
          "userName": { "type": "string" },
          "message": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "isAdmin": { "type": "boolean" }
        }
      },
      "description": "Threaded messages for support tickets"
    },
    "/plans/{planId}": {
      "schema": "Plan",
      "description": "Available subscription plans"
    },
    "/subscriptions/{subId}": {
      "schema": "Subscription",
      "description": "User subscription records"
    },
    "/releases/{releaseId}": {
      "schema": "Release",
      "description": "Music distribution releases"
    },
    "/transactions/{txId}": {
      "schema": "Transaction",
      "description": "Earnings and payment records"
    },
    "/withdrawals/{withdrawalId}": {
      "schema": "WithdrawalRequest",
      "description": "User withdrawal requests"
    },
    "/system_notifications/{notifId}": {
      "schema": "SystemNotification",
      "description": "Global dashboard news"
    },
    "/user_notifications/{notifId}": {
      "schema": {
        "type": "object",
        "properties": {
          "userId": { "type": "string" },
          "title": { "type": "string" },
          "message": { "type": "string" },
          "type": { "type": "string" },
          "read": { "type": "boolean" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "description": "User-specific notifications"
    },
    "/system/{statusId}": {
      "schema": { "type": "object", "properties": { "status": { "type": "string" } } },
      "description": "System health and status"
    }
  }
}
