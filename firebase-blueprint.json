{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and role.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["artist", "admin"] },
        "planId": { "type": "string", "description": "Current subscription plan ID" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Plan": {
      "title": "Pricing Plan",
      "description": "Subscription plan details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "currency": { "type": "string" },
        "interval": { "type": "string", "enum": ["month", "year"] },
        "features": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Subscription": {
      "title": "User Subscription",
      "description": "Details of an active user subscription.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "planId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "canceled", "past_due", "incomplete"] },
        "currentPeriodEnd": { "type": "string", "format": "date-time" }
      }
    },
    "Release": {
      "title": "Music Release",
      "description": "Information about a distributed music release.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "artist": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "live", "rejected"] },
        "coverUrl": { "type": "string" },
        "audioUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Transaction": {
      "title": "Financial Transaction",
      "description": "Earnings and withdrawals records.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["earning", "withdrawal", "subscription"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "SystemNotification": {
      "title": "System Notification",
      "description": "Global alerts and updates for artists.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "warning", "urgent"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "UserRequest": {
      "title": "User Request",
      "description": "Customer requests for metadata changes, profile linking, etc.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "ticketId": { "type": "string" },
        "type": { "type": "string" },
        "subject": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "in_review", "approved", "rejected", "completed"] },
        "priority": { "type": "string", "enum": ["normal", "high", "urgent"] },
        "releaseId": { "type": "string" },
        "releaseTitle": { "type": "string" },
        "data": { "type": "object" },
        "adminResponse": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Mail": {
      "title": "Email Trigger",
      "description": "Trigger automated emails via Firebase Extension.",
      "type": "object",
      "properties": {
        "to": { "type": "array", "items": { "type": "string" } },
        "message": {
          "type": "object",
          "properties": {
            "subject": { "type": "string" },
            "html": { "type": "string" },
            "text": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "ContentIdRequest": {
      "title": "Content ID Request",
      "description": "Requests for YouTube/Social Media Content ID activation.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "releaseId": { "type": "string" },
        "songName": { "type": "string" },
        "artistName": { "type": "string" },
        "songLink": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "adminResponse": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userEmail", "releaseId", "songName", "artistName", "songLink", "status"]
    }
  },
  "firestore": {
    "/mail/{mailId}": {
      "schema": "Mail",
      "description": "Triggered emails collection"
    },
    "/content_id_requests/{requestId}": {
      "schema": "ContentIdRequest",
      "description": "Requests for Content ID protection"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Global user profiles"
    },
    "/user_requests/{requestId}": {
      "schema": "UserRequest",
      "description": "Customer support and metadata requests"
    },
    "/support_tickets/{ticketId}": {
      "schema": "UserRequest",
      "description": "Support tickets (using UserRequest schema)"
    },
    "/support_tickets/{ticketId}/messages/{messageId}": {
      "schema": {
        "type": "object",
        "properties": {
          "userId": { "type": "string" },
          "userName": { "type": "string" },
          "message": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "isAdmin": { "type": "boolean" }
        }
      },
      "description": "Threaded messages for support tickets"
    },
    "/plans/{planId}": {
      "schema": "Plan",
      "description": "Available subscription plans"
    },
    "/subscriptions/{subId}": {
      "schema": "Subscription",
      "description": "User subscription records"
    },
    "/releases/{releaseId}": {
      "schema": "Release",
      "description": "Music distribution releases"
    },
    "/transactions/{txId}": {
      "schema": "Transaction",
      "description": "Earnings and payment records"
    },
    "/system_notifications/{notifId}": {
      "schema": "SystemNotification",
      "description": "Global dashboard news"
    },
    "/system/{statusId}": {
      "schema": { "type": "object", "properties": { "status": { "type": "string" } } },
      "description": "System health and status"
    }
  }
}
