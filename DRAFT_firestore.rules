rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // Phase 3: Primitive Definitions & Helpers
    // -------------------------------------------------------------------------
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Hardcoded master admins from AuthContext.tsx logic
    function isMasterAdmin() {
      return isSignedIn() && (
        request.auth.token.email in ["musicdistributionindia.in@gmail.com", "summyskji@gmail.com"] &&
        request.auth.token.email_verified == true
      );
    }

    function isAdmin() {
      return isMasterAdmin() || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // -------------------------------------------------------------------------
    // Validation Helpers (The Blueprint)
    // -------------------------------------------------------------------------

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             data.role in ['artist', 'admin'];
    }

    function isValidRelease(data) {
      return data.keys().hasAll(['userId', 'title', 'artist', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() <= 200 &&
             data.artist is string && data.artist.size() <= 200 &&
             data.status in ['pending', 'approved', 'live', 'rejected'];
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['userId', 'amount', 'type', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.amount is number &&
             data.type in ['earning', 'withdrawal', 'subscription'];
    }

    // -------------------------------------------------------------------------
    // match blocks
    // -------------------------------------------------------------------------

    match /system/{statusId} {
      allow read: if true; // Public health check
    }

    match /system_notifications/{notifId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /users/{userId} {
      // Pillar 8: Explicit check against userId
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin(); // Only admins can list all users
      
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().role == 'artist';
      allow update: if (isOwner(userId) || isAdmin()) && (
        // Allow updating specific fields like planId or walletBalance
        incoming().diff(existing()).affectedKeys().hasOnly(['planId', 'displayName', 'artistName', 'walletBalance', 'lastPaymentId', 'subscriptionStatus', 'updatedAt'])
      );
    }

    match /plans/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /subscriptions/{subId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin(); // Usually created by system/admin via webhook or portal
    }

    match /releases/{releaseId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidRelease(incoming());
      allow update: if isSignedIn() && (
        (isOwner(existing().userId) && existing().status == 'pending' && isValidRelease(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'artist', 'coverUrl', 'audioUrl'])) ||
        isAdmin()
      );
      allow delete: if isAdmin(); // Restrict deletions to admin
    }

    match /transactions/{txId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isMasterAdmin(); // Transactions should be server-side mostly
      allow write: if isAdmin();
    }
  }
}
