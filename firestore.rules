rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // -------------------------------------------------------------------------
    // HELPERS
    // -------------------------------------------------------------------------
    
    // -------------------------------------------------------------------------
    // HELPERS & VALIDATION BLUEPRINTS
    // -------------------------------------------------------------------------
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // MASTER ADMIN BYPASS
    function isMasterAdmin() {
      return isSignedIn() && (
        request.auth.token.email.lowerCase() == "musicdistributionindia.in@gmail.com" || 
        request.auth.token.email.lowerCase() == "summyskji@gmail.com" ||
        request.auth.token.email.lowerCase() == "admin@musicdistributionindia.in"
      );
    }

    // Role-based Admin check
    function isAdmin() {
      return isSignedIn() && (
        isMasterAdmin() || (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        )
      );
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // VALIDATION HELPERS
    function isValidWithdrawal(data) {
      return data.userId == request.auth.uid &&
             data.userEmail is string &&
             data.amount is number && data.amount >= 500 &&
             data.method in ['UPI', 'BANK'] &&
             data.status == 'pending' &&
             data.createdAt == request.time;
    }

    function isValidTransaction(data) {
      return data.userId is string &&
             data.amount is number &&
             data.type in ['earning', 'withdrawal'] &&
             data.status in ['pending', 'completed', 'failed'] &&
             data.createdAt == request.time;
    }

    // -------------------------------------------------------------------------
    // GLOBAL BYPASS
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if isMasterAdmin();
    }

    // -------------------------------------------------------------------------
    // COLLECTION SPECIFIC RULES
    // -------------------------------------------------------------------------

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && incoming().get('role', 'artist') == 'artist';
      allow update: if (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'planId'])) || isAdmin();
      allow delete: if isAdmin();
    }

    match /releases/{releaseId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /artists/{artistId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /labels/{labelId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /transactions/{txId} {
      allow list: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow get: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isAdmin() || (isOwner(incoming().userId) && isValidTransaction(incoming()));
      allow update, delete: if isAdmin();
    }

    match /withdrawals/{wId} {
      allow list: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow get: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidWithdrawal(incoming()) && isValidId(wId);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /system_notifications/{nId} {
      allow list: if true;
      allow get: if true;
      allow write: if isAdmin();
    }

    match /user_notifications/{nId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, delete: if isAdmin();
    }

    match /oac_requests/{id} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /content_id_requests/{id} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /support_tickets/{id} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /user_requests/{id} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /request_logs/{id} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /plans/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /royalty_reports/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /royalty_entries/{id} {
      allow list: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow get: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }
  }
}
